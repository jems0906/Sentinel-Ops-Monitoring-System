[
  {
    "name": "Gateway Ping",
    "target_type": "ping",
    "address": "1.1.1.1",
    "interval_seconds": 20,
    "enabled": true,
    "extra": {
      "timeout": 2
    }
  },
  {
    "name": "Frontend Service",
    "target_type": "http",
    "address": "http://frontend:5173",
    "interval_seconds": 15,
    "enabled": true,
    "extra": {
      "timeout": 5,
      "expected_status": 200
    }
  },
  {
    "name": "Public DNS Check",
    "target_type": "dns",
    "address": "example.com",
    "interval_seconds": 25,
    "enabled": true,
    "extra": {
      "resolver": "8.8.8.8",
      "record_type": "A"
    }
  }
]
